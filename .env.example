NEXT_PUBLIC_APP_URL=http://localhost:3000
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace_with_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key

# Initial password assigned to all generated accounts on first provisioning.
# Users are forced to change it on first login. Keep this private in production.
LAB_INITIAL_PASSWORD=replace_with_your_own_strong_password

# Optional: Telegram notifications to supervisor when a record is submitted
TELEGRAM_BOT_TOKEN=123456789:replace_with_botfather_token
TELEGRAM_CHAT_ID=replace_with_supervisor_chat_id
